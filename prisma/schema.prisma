datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Company {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  users        User[]
  departments  Department[]
  employees    Employee[]
  projects     Project[]
  tasks        Task[]
  activityLogs ActivityLog[]
  files        File[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String
  password  String
  role      UserRole @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  departments        Department[]  @relation("UserDepartments")
  projects           Project[]     @relation("UserProjects")
  activityLogs       ActivityLog[] @relation("performedByUser")
  employeeOf         Department[]  @relation("DepartmentEmployees") // departments where user is employee
  activityLogsAsUser ActivityLog[] @relation(fields: [], references: [])
  File               File[]
  tasks              Task[]

  @@unique([email, companyId])
  @@index([email])
  @@index([companyId])
}

model Department {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  createdBy   User   @relation("UserDepartments", fields: [createdById], references: [id])
  createdById String

  projects Project[] @relation("DepartmentProjects")

  employees User[] @relation("DepartmentEmployees") // users who are employees of this department

  employeesList Employee[] // opposite relation for Employee.department

  @@index([companyId])
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      ProjectStatus @default(PLANNED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  departments Department[] @relation("DepartmentProjects")
  createdBy   User         @relation("UserProjects", fields: [createdById], references: [id])
  createdById String

  tasks        Task[]
  activityLogs ActivityLog[]

  File File[]

  @@index([companyId])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  activityLogs ActivityLog[]

  employee   Employee? @relation("EmployeeTasks", fields: [employeeId], references: [id])
  employeeId String?
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?

  @@index([status])
  @@index([dueDate])
  @@index([companyId])
}

model ActivityLog {
  id            String   @id @default(uuid())
  action        String
  meta          String?
  entity        String?
  entityType    String? // e.g. PROJECT, TASK, USER
  entityId      String? // related entity ID
  details       String?
  performedBy   User?    @relation("performedByUser", fields: [performedById], references: [id])
  performedById String?
  createdAt     DateTime @default(now())

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  task   Task?   @relation(fields: [taskId], references: [id])
  taskId String?

  @@index([companyId])
}

model Employee {
  id           String     @id @default(uuid())
  name         String
  email        String
  phone        String?
  role         String
  position     String?
  salary       Float?
  company      Company    @relation(fields: [companyId], references: [id])
  companyId    String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  tasks        Task[]     @relation("EmployeeTasks")

  @@unique([email, companyId])
  @@index([companyId])
}

model File {
  id           String   @id @default(uuid())
  filename     String
  path         String
  mimetype     String
  size         Int
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  project      Project? @relation(fields: [projectId], references: [id])
  projectId    String?
  createdAt    DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  @@index([companyId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
